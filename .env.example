# Copy: cp .env.example .env
# Then choose ONE option below. Use one line per variable, no quotes, no space around =

# --- Option A: OpenAI (paid; requires billing) ---
# OPENAI_API_KEY=sk-proj-...
# LLM_MODEL=gpt-4o-mini

# --- Option B: Ollama (free, local) ---
# 1. Install: https://ollama.com
# 2. Pull a model:  ollama pull llama3.2   (or  ollama pull phi3  for smaller)
# 3. Check name:  ollama list   → use that exact NAME as LLM_MODEL
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# LLM_MODEL=llama3.2

# --- Option C: Groq (free tier; fast) ---
# Get key: https://console.groq.com/keys
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_API_KEY=gsk_...
# LLM_MODEL=llama-3.1-70b-versatile

# --- Option D: OpenRouter (some free models) ---
# Get key: https://openrouter.ai/keys
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-or-...
# LLM_MODEL=google/gemma-2-9b-it:free

# --- Streamlit: override API URL (default http://localhost:8000) ---
# API_URL=http://localhost:8000

# --- RAG API (optional) ---
# SCORE_THRESHOLD=0.3   # If best retrieval score below this, return "I don't have enough information" (no LLM call)
# MAX_QUESTION_LENGTH=1000   # Max characters for question; 422 if exceeded
# USE_HYBRID_RERANK=1   # Lightweight quality boost: combines semantic similarity + keyword overlap
# HYBRID_RERANK_ALPHA=0.75   # 0.0=lexical only, 1.0=semantic only
# RATE_LIMIT_REQUESTS=0   # Per-IP limit for /ask and /ask/stream; 0 = disabled (MVP default)
# RATE_LIMIT_WINDOW_SECONDS=60
# RATE_LIMIT_BACKEND=memory   # MVP default: no DB. Use sqlite only if you need host-shared limits.
# RATE_LIMIT_DB_PATH=data/rate_limit.db   # Used only when RATE_LIMIT_BACKEND=sqlite
# PRELOAD_RETRIEVER_ON_STARTUP=false   # Keep false on small instances to avoid startup memory spikes
# ALLOW_IN_MEMORY_INDEX_FALLBACK=false   # Keep false on hosted env; require built FAISS index
# CORS_ALLOW_ORIGINS=https://your-frontend.example.com   # production: explicit origins (comma-separated)
# CORS_ALLOW_CREDENTIALS=false   # set true only with explicit origins (not "*")
# USE_RERANKER=1   # Retrieve more, then rerank with cross-encoder (better relevance, slower)
# RERANK_RETRIEVE_K=15   # How many to retrieve before reranking to TOP_K
# PDF_PATHS=ca-drivers-handbook.pdf   # Comma-separated paths under data/ for multiple PDFs
# USE_SEMANTIC_CHUNKING=1   # Chunk by paragraphs (avoids mid-sentence splits)
